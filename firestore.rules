rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas para usuarios
    match /usuarios/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.uid == userId || 
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin');
    }
    
    // Reglas para cursos
    match /cursos/{cursoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin' ||
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'profesor');
    }
    
    // Reglas para recursos
    match /recursos/{recursoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol in ['admin', 'profesor'];
    }
    
    // Reglas para progreso
    match /progreso/{progresoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol in ['admin', 'profesor'] ||
         request.auth.uid == resource.data.estudiante);
    }
  }
}